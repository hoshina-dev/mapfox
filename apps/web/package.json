    "@types/node": "^24.9.2",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/ui": "^4.0.8",
    "eslint": "^9.39.0",
    "jsdom": "^27.1.0",
    "typescript": "5.9.3",
    "vitest": "^4.0.8"
